# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://fitandfine:fitandfine_dev@localhost:5432/fitandfine
DATABASE_URL_SYNC=postgresql://fitandfine:fitandfine_dev@localhost:5432/fitandfine

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — RS256 keys (generate with: openssl genrsa -out private.pem 2048)
SECRET_KEY=your-secret-key-min-32-chars-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Apple Sign In
APPLE_APP_BUNDLE_ID=com.fitandfine.app
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# USDA FoodData Central
USDA_API_KEY=your-usda-api-key

# AWS S3 (Phase 2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=fitandfine-scans

# Rate limits
AI_COACH_MESSAGES_PER_DAY=50
AI_COACH_MESSAGES_PER_HOUR=10
AI_RECOMMENDATIONS_PER_DAY=20
LABEL_SCANS_PER_DAY=30
